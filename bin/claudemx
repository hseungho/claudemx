#!/bin/zsh

# claudemx - tmux 기반 Claude Code 멀티 에이전트 런처
# 사용법:
#   claudemx --agent N                      N개의 독립적인 claude 세션 생성
#   claudemx --orchestration [--teammates N] Agent Teams 오케스트레이션 모드
#   claudemx --update                       GitHub에서 최신 버전으로 업데이트

set -e

VERSION="v0.0.3"

# 최신 릴리스 태그 조회
get_latest_version() {
  curl -fsSL --max-time 5 \
    "https://api.github.com/repos/hseungho/claudemx/releases/latest" 2>/dev/null \
    | grep -o '"tag_name": *"[^"]*"' | head -1 | cut -d'"' -f4
}

# 백그라운드 업데이트 체크
background_update_check() {
  local tmpfile="$1"
  local latest
  latest=$(get_latest_version)
  if [[ -n "$latest" && "$latest" != "$VERSION" ]]; then
    echo "$latest" > "$tmpfile"
  fi
}

# 기본값
MODE="agent"
AGENT_COUNT=2
SESSION_NAME=""
TEAMMATE_COUNT=""

# 인자 파싱
while [[ $# -gt 0 ]]; do
  case $1 in
    --agent|-a)
      MODE="agent"
      AGENT_COUNT="$2"
      shift 2
      ;;
    --orchestration|-o)
      MODE="orchestration"
      shift
      ;;
    --teammates|-t)
      TEAMMATE_COUNT="$2"
      shift 2
      ;;
    --session|-s)
      SESSION_NAME="$2"
      shift 2
      ;;
    --version|-v)
      echo "claudemx $VERSION"
      exit 0
      ;;
    --update|-u)
      MODE="update"
      shift
      ;;
    --check-update)
      MODE="check-update"
      shift
      ;;
    --help|-h)
      echo "사용법: claudemx [옵션]"
      echo ""
      echo "모드:"
      echo "  --agent, -a N            독립적인 claude 세션 N개 생성 (기본: 2, 최대: 9)"
      echo "  --orchestration, -o      Agent Teams 오케스트레이션 모드"
      echo ""
      echo "옵션:"
      echo "  --teammates, -t N        오케스트레이션 모드에서 teammate 수 힌트 (1~9)"
      echo "  --session, -s NAME       tmux 세션 이름"
      echo "                           기본: claude-agents (agent) / claude-orchestration (orchestration)"
      echo "  --version, -v            버전 출력"
      echo "  --update, -u             GitHub에서 최신 버전으로 업데이트"
      echo "  --check-update           새 버전 확인만 (업데이트하지 않음)"
      echo "  --help, -h               도움말"
      echo ""
      echo "예시:"
      echo "  claudemx --agent 4"
      echo "  claudemx --orchestration"
      echo "  claudemx --orchestration --teammates 3"
      echo "  claudemx --orchestration --session my-project"
      echo "  claudemx --update"
      echo ""
      echo "오케스트레이션 모드 조작:"
      echo "  Shift+Down    teammate 패널 순환"
      echo "  Ctrl+T        공유 task list 토글"
      echo "  Ctrl+B 방향키  tmux 패널 이동"
      exit 0
      ;;
    *)
      echo "알 수 없는 옵션: $1"
      echo "claudemx --help 로 사용법을 확인하세요."
      exit 1
      ;;
  esac
done

if [[ "$MODE" == "check-update" ]]; then
  LATEST=$(get_latest_version)
  if [[ -z "$LATEST" ]]; then
    echo "오류: GitHub에서 최신 버전을 확인할 수 없습니다."
    exit 1
  fi

  if [[ "$VERSION" == "$LATEST" ]]; then
    echo "이미 최신 버전입니다. ($VERSION)"
  else
    echo "새 버전 ${LATEST}이 있습니다. claudemx --update로 업데이트하세요"
  fi
  exit 0
fi

# ─────────────────────────────────────────────
# 업데이트 모드
# ─────────────────────────────────────────────
if [[ "$MODE" == "update" ]]; then
  BIN_DIR="$HOME/.local/bin"
  COMPLETION_DIR="$HOME/.local/share/zsh/completions"
  TMPDIR_UPDATE=$(mktemp -d)
  trap "rm -rf $TMPDIR_UPDATE" EXIT

  echo "▶ claudemx 업데이트 확인 중..."

  LATEST=$(get_latest_version)
  if [[ -z "$LATEST" ]]; then
    echo "오류: GitHub에서 최신 버전을 확인할 수 없습니다."
    exit 1
  fi

  if [[ "$VERSION" == "$LATEST" ]]; then
    echo "  이미 최신 버전입니다. ($VERSION)"
    exit 0
  fi

  echo "  새 버전: $VERSION → $LATEST"

  GITHUB_RAW="https://raw.githubusercontent.com/hseungho/claudemx/$LATEST"

  if ! curl -fsSL "$GITHUB_RAW/bin/claudemx" -o "$TMPDIR_UPDATE/claudemx"; then
    echo "오류: 최신 버전을 다운로드할 수 없습니다."
    exit 1
  fi

  cp "$TMPDIR_UPDATE/claudemx" "$BIN_DIR/claudemx"
  chmod +x "$BIN_DIR/claudemx"
  echo "  ✓ claudemx $LATEST 업데이트 완료"

  if curl -fsSL "$GITHUB_RAW/bin/_claudemx" -o "$TMPDIR_UPDATE/_claudemx" 2>/dev/null; then
    mkdir -p "$COMPLETION_DIR"
    cp "$TMPDIR_UPDATE/_claudemx" "$COMPLETION_DIR/_claudemx"
    echo "  ✓ zsh 자동완성 업데이트 완료"
  fi

  echo ""
  echo "  업데이트가 적용되었습니다."
  exit 0
fi

# 세션 이름 기본값
if [[ -z "$SESSION_NAME" ]]; then
  if [[ "$MODE" == "orchestration" ]]; then
    SESSION_NAME="claude-orchestration"
  else
    SESSION_NAME="claude-agents"
  fi
fi

# 백그라운드 업데이트 체크 시작
UPDATE_CHECK_TMP=$(mktemp /tmp/claudemx-update-check.XXXXXX)
background_update_check "$UPDATE_CHECK_TMP" &
UPDATE_CHECK_PID=$!

# 이미 존재하는 세션이면 attach
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  echo "기존 세션 '$SESSION_NAME'에 연결합니다."
  tmux attach -t "$SESSION_NAME"
  exit 0
fi

# ─────────────────────────────────────────────
# 오케스트레이션 모드
# ─────────────────────────────────────────────
if [[ "$MODE" == "orchestration" ]]; then
  # Claude Code 설치 확인
  if ! claude --version &>/dev/null; then
    echo "오류: claude 명령어를 찾을 수 없습니다."
    exit 1
  fi

  # Agent Teams 환경변수 확인
  SETTINGS_FILE="$HOME/.claude/settings.json"
  AGENT_TEAMS_ENABLED=false
  if [[ -n "${CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS:-}" ]]; then
    AGENT_TEAMS_ENABLED=true
  elif [[ -f "$SETTINGS_FILE" ]] && grep -q '"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS"' "$SETTINGS_FILE" 2>/dev/null; then
    AGENT_TEAMS_ENABLED=true
  fi

  if [[ "$AGENT_TEAMS_ENABLED" == "false" ]]; then
    echo "오류: Agent Teams가 활성화되어 있지 않습니다."
    echo ""
    echo "다음 중 하나로 활성화하세요:"
    echo "  1) claude settings set env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS 1"
    echo "  2) ~/.claude/settings.json 에 직접 추가:"
    echo '     { "env": { "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1" } }'
    exit 1
  fi

  # teammate 수 유효성 검사
  if [[ -n "$TEAMMATE_COUNT" ]]; then
    if [[ $TEAMMATE_COUNT -lt 1 || $TEAMMATE_COUNT -gt 9 ]]; then
      echo "teammate 수는 1~9 사이여야 합니다."
      exit 1
    fi
  fi

  # 리드 에이전트 세션 생성
  tmux new-session -d -s "$SESSION_NAME"
  tmux send-keys -t "$SESSION_NAME" "claude" Enter

  # claude 준비 대기 (pane에 출력이 충분히 나올 때까지)
  ELAPSED=0
  while [[ $ELAPSED -lt 30 ]]; do
    sleep 0.5
    ELAPSED=$((ELAPSED + 1))
    LINE_COUNT=$(tmux capture-pane -t "$SESSION_NAME" -p 2>/dev/null | grep -c '.' || true)
    if [[ $LINE_COUNT -ge 3 ]]; then
      break
    fi
  done
  sleep 1

  # Agent Teams 프롬프트 자동 전송
  if [[ -n "$TEAMMATE_COUNT" ]]; then
    TEAM_PROMPT="create an agent team with ${TEAMMATE_COUNT} teammates to work on this project"
  else
    TEAM_PROMPT="create an agent team to help with tasks in this project"
  fi
  tmux send-keys -t "$SESSION_NAME" "$TEAM_PROMPT" Enter

  echo ""
  echo "┌─────────────────────────────────────────────────────┐"
  echo "│  Claude Code Agent Teams 오케스트레이션 모드         │"
  echo "│  세션: $SESSION_NAME"
  echo "│                                                     │"
  echo "│  teammate 수: ${TEAMMATE_COUNT:-자동 결정}"
  echo "│                                                     │"
  echo "│  Shift+Down   teammate 패널 순환                    │"
  echo "│  Ctrl+T       공유 task list 토글                   │"
  echo "│  Ctrl+B 방향키  tmux 패널 이동                      │"
  echo "└─────────────────────────────────────────────────────┘"
  echo ""

  # 백그라운드 업데이트 체크 결과 확인
  if [[ -n "${UPDATE_CHECK_PID:-}" ]]; then
    wait "$UPDATE_CHECK_PID" 2>/dev/null || true
    if [[ -s "$UPDATE_CHECK_TMP" ]]; then
      LATEST_VER=$(cat "$UPDATE_CHECK_TMP")
      echo "새 버전 ${LATEST_VER}이 있습니다. claudemx --update로 업데이트하세요"
      echo ""
    fi
    rm -f "$UPDATE_CHECK_TMP"
  fi

  tmux attach -t "$SESSION_NAME"
  exit 0
fi

# ─────────────────────────────────────────────
# 에이전트 모드 (기존 --agent 동작)
# ─────────────────────────────────────────────

# 유효성 검사
if [[ $AGENT_COUNT -lt 1 || $AGENT_COUNT -gt 9 ]]; then
  echo "에이전트 수는 1~9 사이여야 합니다."
  exit 1
fi

# 레이아웃 계산 (가로 x 세로)
if [[ $AGENT_COUNT -eq 1 ]]; then
  COLS=1; ROWS=1
elif [[ $AGENT_COUNT -eq 2 ]]; then
  COLS=2; ROWS=1
elif [[ $AGENT_COUNT -le 4 ]]; then
  COLS=2; ROWS=2
elif [[ $AGENT_COUNT -le 6 ]]; then
  COLS=3; ROWS=2
else
  COLS=3; ROWS=3
fi

# 세션 생성 (첫 번째 pane)
tmux new-session -d -s "$SESSION_NAME"
tmux send-keys -t "$SESSION_NAME" 'claude' Enter

# 나머지 pane 생성
for ((i=2; i<=AGENT_COUNT; i++)); do
  if (( i <= COLS )); then
    # 첫 번째 행: 수평 분할
    tmux split-window -h -t "$SESSION_NAME"
  else
    # 다음 행: 대상 pane에서 수직 분할
    TARGET_PANE=$(( i - COLS - 1 ))
    tmux split-window -v -t "$SESSION_NAME.$TARGET_PANE"
  fi
  tmux send-keys 'claude' Enter
done

# 레이아웃 균등 정렬
tmux select-layout -t "$SESSION_NAME" tiled

# 첫 번째 pane 선택
tmux select-pane -t "$SESSION_NAME.0"

echo "Claude Code $AGENT_COUNT개 에이전트 시작 (세션: $SESSION_NAME)"
echo "조작법: Ctrl+B 방향키로 pane 이동"

# 백그라운드 업데이트 체크 결과 확인
if [[ -n "${UPDATE_CHECK_PID:-}" ]]; then
  wait "$UPDATE_CHECK_PID" 2>/dev/null || true
  if [[ -s "$UPDATE_CHECK_TMP" ]]; then
    LATEST_VER=$(cat "$UPDATE_CHECK_TMP")
    echo "새 버전 ${LATEST_VER}이 있습니다. claudemx --update로 업데이트하세요"
    echo ""
  fi
  rm -f "$UPDATE_CHECK_TMP"
fi

# 세션에 연결
tmux attach -t "$SESSION_NAME"
