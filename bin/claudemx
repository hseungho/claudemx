#!/bin/zsh

# claudemx - tmux 기반 Claude Code 멀티 에이전트 런처
# 사용법:
#   claudemx --agent N                      N개의 독립적인 claude 세션 생성
#   claudemx --orchestration [--teammates N] Agent Teams 오케스트레이션 모드
#   claudemx --update                       GitHub에서 최신 버전으로 업데이트

set -e

VERSION="v0.0.5"

# 최신 릴리스 태그 조회
get_latest_version() {
  curl -fsSL --max-time 5 \
    "https://api.github.com/repos/hseungho/claudemx/releases/latest" 2>/dev/null \
    | grep -o '"tag_name": *"[^"]*"' | head -1 | cut -d'"' -f4
}

# 백그라운드 업데이트 체크
background_update_check() {
  local tmpfile="$1"
  local latest
  latest=$(get_latest_version)
  if [[ -n "$latest" && "$latest" != "$VERSION" ]]; then
    echo "$latest" > "$tmpfile"
  fi
}

# 초를 사람이 읽을 수 있는 형식으로 변환
format_uptime() {
  local seconds=$1
  local days=$((seconds / 86400))
  local hours=$(( (seconds % 86400) / 3600 ))
  local minutes=$(( (seconds % 3600) / 60 ))

  if [[ $days -gt 0 ]]; then
    echo "${days}d ${hours}h"
  elif [[ $hours -gt 0 ]]; then
    echo "${hours}h ${minutes}m"
  else
    echo "${minutes}m"
  fi
}

# 기본값
MODE="agent"
AGENT_COUNT=1
SESSION_NAME=""
TEAMMATE_COUNT=""
FORCE_NEW=false
FORCE=false
ATTACH_SESSION=""
KILL_SESSIONS=()

# 인자 파싱
while [[ $# -gt 0 ]]; do
  case $1 in
    --agent|-a)
      MODE="agent"
      AGENT_COUNT="$2"
      shift 2
      ;;
    --orchestration|-o)
      MODE="orchestration"
      shift
      ;;
    --teammates|-t)
      TEAMMATE_COUNT="$2"
      shift 2
      ;;
    --session|-s)
      ATTACH_SESSION="$2"
      shift 2
      ;;
    --new|-n)
      FORCE_NEW=true
      shift
      ;;
    --version|-v)
      echo "claudemx $VERSION"
      exit 0
      ;;
    --update|-u)
      MODE="update"
      shift
      ;;
    --list|-l)
      MODE="list"
      shift
      ;;
    --kill|-k)
      MODE="kill"
      shift
      KILL_SESSIONS=()
      while [[ $# -gt 0 && ! "$1" == --* ]]; do
        KILL_SESSIONS+=("$1")
        shift
      done
      if [[ ${#KILL_SESSIONS[@]} -eq 0 ]]; then
        echo "사용법: claudemx --kill <세션이름> [세션이름...]"
        exit 1
      fi
      ;;
    --prune)
      MODE="prune"
      shift
      ;;
    -f)
      FORCE=true
      shift
      ;;
    --check-update)
      MODE="check-update"
      shift
      ;;
    --help|-h)
      echo "사용법: claudemx [옵션]"
      echo ""
      echo "모드:"
      echo "  --agent, -a N            독립적인 claude 세션 N개 생성 (기본: 2, 최대: 9)"
      echo "  --orchestration, -o      Agent Teams 오케스트레이션 모드"
      echo ""
      echo "옵션:"
      echo "  --teammates, -t N        오케스트레이션 모드에서 teammate 수 힌트 (1~9)"
      echo "  --list, -l               실행 중인 claudemx 세션 목록 표시"
      echo "  --kill, -k NAME...       지정한 claudemx 세션 종료"
      echo "  --prune                  모든 claudemx 세션 종료 (확인 프롬프트)"
      echo "  -f                       --prune 시 확인 없이 즉시 종료"
      echo "  --session, -s NAME       기존 tmux 세션에 연결"
      echo "  --new, -n                새 세션 강제 생성 (--session과 함께 사용 시)"
      echo "  --version, -v            버전 출력"
      echo "  --update, -u             GitHub에서 최신 버전으로 업데이트"
      echo "  --check-update           새 버전 확인만 (업데이트하지 않음)"
      echo "  --help, -h               도움말"
      echo ""
      echo "예시:"
      echo "  claudemx --agent 4"
      echo "  claudemx --orchestration"
      echo "  claudemx --orchestration --teammates 3"
      echo "  claudemx --orchestration --session my-project"
      echo "  claudemx --update"
      echo ""
      echo "오케스트레이션 모드 조작:"
      echo "  Shift+Down    teammate 패널 순환"
      echo "  Ctrl+T        공유 task list 토글"
      echo "  Ctrl+B 방향키  tmux 패널 이동"
      exit 0
      ;;
    *)
      echo "알 수 없는 옵션: $1"
      echo "claudemx --help 로 사용법을 확인하세요."
      exit 1
      ;;
  esac
done

if [[ "$MODE" == "list" ]]; then
  printf "%-20s %-18s %-12s %-10s %s\n" "SESSION" "MODE" "TEAMMATES" "UPTIME" "DIRECTORY"

  tmux list-sessions -F '#{session_name} #{session_created}' 2>/dev/null | while read -r session_name session_created; do
    # claudemx 세션인지 확인
    local cmx_env
    cmx_env=$(tmux show-environment -t "$session_name" CLAUDEMX 2>/dev/null) || continue
    [[ "$cmx_env" == "CLAUDEMX=true" ]] || continue

    # 모드 확인
    local mode_env mode_display teammates
    mode_env=$(tmux show-environment -t "$session_name" CLAUDEMX_MODE 2>/dev/null)
    local mode_value="${mode_env#CLAUDEMX_MODE=}"

    # pane 수 조회
    local pane_count
    pane_count=$(tmux list-panes -t "$session_name" 2>/dev/null | wc -l | tr -d ' ')

    if [[ "$mode_value" == "orchestration" ]]; then
      mode_display="orchestration"
      teammates=$((pane_count - 1))
    else
      mode_display="agent(${pane_count})"
      teammates="-"
    fi

    # uptime 계산
    local now uptime_seconds uptime_display
    now=$(date +%s)
    uptime_seconds=$((now - session_created))
    uptime_display=$(format_uptime "$uptime_seconds")

    # 작업 디렉토리 (첫 번째 pane 기준)
    local directory
    directory=$(tmux display-message -t "$session_name:0.0" -p '#{pane_current_path}' 2>/dev/null)
    directory="${directory/#$HOME/~}"

    printf "%-20s %-18s %-12s %-10s %s\n" "$session_name" "$mode_display" "$teammates" "$uptime_display" "$directory"
  done

  exit 0
fi

if [[ "$MODE" == "kill" ]]; then
  for session_name in "${KILL_SESSIONS[@]}"; do
    # 세션 존재 확인
    if ! tmux has-session -t "$session_name" 2>/dev/null; then
      echo "세션 '${session_name}'을(를) 찾을 수 없습니다"
      continue
    fi

    # claudemx 세션인지 확인
    local cmx_env
    cmx_env=$(tmux show-environment -t "$session_name" CLAUDEMX 2>/dev/null) || true
    if [[ "$cmx_env" != "CLAUDEMX=true" ]]; then
      echo "세션 '${session_name}'은(는) claudemx 세션이 아닙니다"
      continue
    fi

    tmux kill-session -t "$session_name"
    echo "세션 '${session_name}' 종료됨"
  done
  exit 0
fi

if [[ "$MODE" == "prune" ]]; then
  # claudemx 세션 수집
  PRUNE_SESSIONS=()
  while IFS= read -r session_name; do
    [[ -z "$session_name" ]] && continue
    local cmx_env
    cmx_env=$(tmux show-environment -t "$session_name" CLAUDEMX 2>/dev/null) || continue
    [[ "$cmx_env" == "CLAUDEMX=true" ]] || continue
    PRUNE_SESSIONS+=("$session_name")
  done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null)

  local count=${#PRUNE_SESSIONS[@]}

  if [[ $count -eq 0 ]]; then
    echo "종료할 세션이 없습니다"
    exit 0
  fi

  # 확인 프롬프트 (-f가 아닐 때)
  if [[ "$FORCE" == "false" ]]; then
    printf "%d개 세션을 모두 종료하시겠습니까? (y/N) " "$count"
    read -r answer
    if [[ "$answer" != "y" && "$answer" != "Y" ]]; then
      echo "취소됨"
      exit 0
    fi
  fi

  for session_name in "${PRUNE_SESSIONS[@]}"; do
    tmux kill-session -t "$session_name"
  done
  echo "${count}개 세션 종료됨"
  exit 0
fi

if [[ "$MODE" == "check-update" ]]; then
  LATEST=$(get_latest_version)
  if [[ -z "$LATEST" ]]; then
    echo "오류: GitHub에서 최신 버전을 확인할 수 없습니다."
    exit 1
  fi

  if [[ "$VERSION" == "$LATEST" ]]; then
    echo "이미 최신 버전입니다. ($VERSION)"
  else
    echo "새 버전 ${LATEST}이 있습니다. claudemx --update로 업데이트하세요"
  fi
  exit 0
fi

# ─────────────────────────────────────────────
# 업데이트 모드
# ─────────────────────────────────────────────
if [[ "$MODE" == "update" ]]; then
  BIN_DIR="$HOME/.local/bin"
  COMPLETION_DIR="$HOME/.local/share/zsh/completions"
  TMPDIR_UPDATE=$(mktemp -d)
  trap "rm -rf $TMPDIR_UPDATE" EXIT

  echo "▶ claudemx 업데이트 확인 중..."

  LATEST=$(get_latest_version)
  if [[ -z "$LATEST" ]]; then
    echo "오류: GitHub에서 최신 버전을 확인할 수 없습니다."
    exit 1
  fi

  if [[ "$VERSION" == "$LATEST" ]]; then
    echo "  이미 최신 버전입니다. ($VERSION)"
    exit 0
  fi

  echo "  새 버전: $VERSION → $LATEST"

  GITHUB_RAW="https://raw.githubusercontent.com/hseungho/claudemx/$LATEST"

  if ! curl -fsSL "$GITHUB_RAW/bin/claudemx" -o "$TMPDIR_UPDATE/claudemx"; then
    echo "오류: 최신 버전을 다운로드할 수 없습니다."
    exit 1
  fi

  cp "$TMPDIR_UPDATE/claudemx" "$BIN_DIR/claudemx"
  chmod +x "$BIN_DIR/claudemx"
  echo "  ✓ claudemx $LATEST 업데이트 완료"

  if curl -fsSL "$GITHUB_RAW/bin/_claudemx" -o "$TMPDIR_UPDATE/_claudemx" 2>/dev/null; then
    mkdir -p "$COMPLETION_DIR"
    cp "$TMPDIR_UPDATE/_claudemx" "$COMPLETION_DIR/_claudemx"
    echo "  ✓ zsh 자동완성 업데이트 완료"
  fi

  echo ""
  echo "  업데이트가 적용되었습니다."
  exit 0
fi

# --session: 기존 세션에 연결
if [[ -n "$ATTACH_SESSION" && "$FORCE_NEW" == "false" ]]; then
  if tmux has-session -t "$ATTACH_SESSION" 2>/dev/null; then
    echo "기존 세션 '$ATTACH_SESSION'에 연결합니다."
    tmux attach -t "$ATTACH_SESSION"
    exit 0
  else
    echo "오류: 세션 '$ATTACH_SESSION'을(를) 찾을 수 없습니다."
    echo ""
    echo "사용 가능한 세션:"
    tmux list-sessions -F '  #{session_name}' 2>/dev/null || echo "  (없음)"
    exit 1
  fi
fi

# 세션 이름 결정
if [[ -n "$ATTACH_SESSION" ]]; then
  # --session + --new: 지정된 이름으로 새 세션 생성
  SESSION_NAME="$ATTACH_SESSION"
else
  if [[ "$MODE" == "orchestration" ]]; then
    SESSION_NAME="claude-orchestration"
  else
    SESSION_NAME="claude-agents"
  fi
fi

# 이름 충돌 시 suffix 추가 (-2, -3, ...)
BASE_NAME="$SESSION_NAME"
SUFFIX=1
while tmux has-session -t "$SESSION_NAME" 2>/dev/null; do
  SUFFIX=$((SUFFIX + 1))
  SESSION_NAME="${BASE_NAME}-${SUFFIX}"
done

# 백그라운드 업데이트 체크 시작
UPDATE_CHECK_TMP=$(mktemp /tmp/claudemx-update-check.XXXXXX)
background_update_check "$UPDATE_CHECK_TMP" &
UPDATE_CHECK_PID=$!

# ─────────────────────────────────────────────
# 오케스트레이션 모드
# ─────────────────────────────────────────────
if [[ "$MODE" == "orchestration" ]]; then
  # Claude Code 설치 확인
  if ! claude --version &>/dev/null; then
    echo "오류: claude 명령어를 찾을 수 없습니다."
    exit 1
  fi

  # Agent Teams 환경변수 확인
  SETTINGS_FILE="$HOME/.claude/settings.json"
  AGENT_TEAMS_ENABLED=false
  if [[ -n "${CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS:-}" ]]; then
    AGENT_TEAMS_ENABLED=true
  elif [[ -f "$SETTINGS_FILE" ]] && grep -q '"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS"' "$SETTINGS_FILE" 2>/dev/null; then
    AGENT_TEAMS_ENABLED=true
  fi

  if [[ "$AGENT_TEAMS_ENABLED" == "false" ]]; then
    echo "오류: Agent Teams가 활성화되어 있지 않습니다."
    echo ""
    echo "다음 중 하나로 활성화하세요:"
    echo "  1) claude settings set env.CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS 1"
    echo "  2) ~/.claude/settings.json 에 직접 추가:"
    echo '     { "env": { "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1" } }'
    exit 1
  fi

  # teammate 수 유효성 검사
  if [[ -n "$TEAMMATE_COUNT" ]]; then
    if [[ $TEAMMATE_COUNT -lt 1 || $TEAMMATE_COUNT -gt 9 ]]; then
      echo "teammate 수는 1~9 사이여야 합니다."
      exit 1
    fi
  fi

  # 리드 에이전트 세션 생성
  tmux new-session -d -s "$SESSION_NAME"

  # claudemx 세션 식별용 환경변수 설정
  tmux set-environment -t "$SESSION_NAME" CLAUDEMX "true"
  tmux set-environment -t "$SESSION_NAME" CLAUDEMX_MODE "orchestration"

  tmux send-keys -t "$SESSION_NAME" "claude" Enter

  # claude 준비 대기 (pane에 출력이 충분히 나올 때까지)
  ELAPSED=0
  while [[ $ELAPSED -lt 30 ]]; do
    sleep 0.5
    ELAPSED=$((ELAPSED + 1))
    LINE_COUNT=$(tmux capture-pane -t "$SESSION_NAME" -p 2>/dev/null | grep -c '.' || true)
    if [[ $LINE_COUNT -ge 3 ]]; then
      break
    fi
  done
  sleep 1

  # Agent Teams 프롬프트 자동 전송
  if [[ -n "$TEAMMATE_COUNT" ]]; then
    TEAM_PROMPT="create an agent team with ${TEAMMATE_COUNT} teammates to work on this project"
  else
    TEAM_PROMPT="create an agent team to help with tasks in this project"
  fi
  tmux send-keys -t "$SESSION_NAME" "$TEAM_PROMPT" Enter

  echo ""
  echo "┌─────────────────────────────────────────────────────┐"
  echo "│  Claude Code Agent Teams 오케스트레이션 모드         │"
  echo "│  세션: $SESSION_NAME"
  echo "│                                                     │"
  echo "│  teammate 수: ${TEAMMATE_COUNT:-자동 결정}"
  echo "│                                                     │"
  echo "│  Shift+Down   teammate 패널 순환                    │"
  echo "│  Ctrl+T       공유 task list 토글                   │"
  echo "│  Ctrl+B 방향키  tmux 패널 이동                      │"
  echo "└─────────────────────────────────────────────────────┘"
  echo ""

  # 백그라운드 업데이트 체크 결과 확인
  if [[ -n "${UPDATE_CHECK_PID:-}" ]]; then
    wait "$UPDATE_CHECK_PID" 2>/dev/null || true
    if [[ -s "$UPDATE_CHECK_TMP" ]]; then
      LATEST_VER=$(cat "$UPDATE_CHECK_TMP")
      echo "새 버전 ${LATEST_VER}이 있습니다. claudemx --update로 업데이트하세요"
      echo ""
    fi
    rm -f "$UPDATE_CHECK_TMP"
  fi

  tmux attach -t "$SESSION_NAME"
  exit 0
fi

# ─────────────────────────────────────────────
# 에이전트 모드 (기존 --agent 동작)
# ─────────────────────────────────────────────

# 유효성 검사
if [[ $AGENT_COUNT -lt 1 || $AGENT_COUNT -gt 9 ]]; then
  echo "에이전트 수는 1~9 사이여야 합니다."
  exit 1
fi

# 레이아웃 계산 (가로 x 세로)
if [[ $AGENT_COUNT -eq 1 ]]; then
  COLS=1; ROWS=1
elif [[ $AGENT_COUNT -eq 2 ]]; then
  COLS=2; ROWS=1
elif [[ $AGENT_COUNT -le 4 ]]; then
  COLS=2; ROWS=2
elif [[ $AGENT_COUNT -le 6 ]]; then
  COLS=3; ROWS=2
else
  COLS=3; ROWS=3
fi

# 세션 생성 (첫 번째 pane)
tmux new-session -d -s "$SESSION_NAME"

# claudemx 세션 식별용 환경변수 설정
tmux set-environment -t "$SESSION_NAME" CLAUDEMX "true"
tmux set-environment -t "$SESSION_NAME" CLAUDEMX_MODE "agent"

tmux send-keys -t "$SESSION_NAME" 'claude' Enter

# 나머지 pane 생성
for ((i=2; i<=AGENT_COUNT; i++)); do
  if (( i <= COLS )); then
    # 첫 번째 행: 수평 분할
    tmux split-window -h -t "$SESSION_NAME"
  else
    # 다음 행: 대상 pane에서 수직 분할
    TARGET_PANE=$(( i - COLS - 1 ))
    tmux split-window -v -t "$SESSION_NAME.$TARGET_PANE"
  fi
  tmux send-keys 'claude' Enter
done

# 레이아웃 균등 정렬
tmux select-layout -t "$SESSION_NAME" tiled

# 첫 번째 pane 선택
tmux select-pane -t "$SESSION_NAME.0"

echo "Claude Code $AGENT_COUNT개 에이전트 시작 (세션: $SESSION_NAME)"
echo "조작법: Ctrl+B 방향키로 pane 이동"

# 백그라운드 업데이트 체크 결과 확인
if [[ -n "${UPDATE_CHECK_PID:-}" ]]; then
  wait "$UPDATE_CHECK_PID" 2>/dev/null || true
  if [[ -s "$UPDATE_CHECK_TMP" ]]; then
    LATEST_VER=$(cat "$UPDATE_CHECK_TMP")
    echo "새 버전 ${LATEST_VER}이 있습니다. claudemx --update로 업데이트하세요"
    echo ""
  fi
  rm -f "$UPDATE_CHECK_TMP"
fi

# 세션에 연결
tmux attach -t "$SESSION_NAME"
